# Lovli — environment variables (set these in Vercel project settings)

# Shared secret Trek2Summit sends in the X-Lovli-Token header on /api/vectorization/callback
LOVLI_WEBHOOK_TOKEN=

# Supabase (dedicated Lovli project) — service role key is server-only, never expose to client
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
